{
  "name": "webcam-calibrator",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "ship:watch": "vite build --watch 2>&1 | tee /tmp/ship-watch.log",
    "typecheck:watch": "tsc --noEmit --watch 2>&1 | tee /tmp/tsc-watch.log",
    "check": "tsx scripts/check.ts",
    "test:subpixel": "vitest run src/tests/subpixel",
    "test:decode": "vitest run src/tests/decode",
    "test": "vitest run",
    "format": "oxfmt",
    "lint": "oxlint"
  },
  "dependencies": {
    "@solidjs/web": "2.0.0-beta.7",
    "solid-js": "2.0.0-beta.7",
    "typegpu": "^0.11.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^25.6.0",
    "@webgpu/types": "^0.1.55",
    "babel-preset-solid": "2.0.0-beta.7",
    "jsdom": "^29.0.2",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "pngjs": "^7.0.0",
    "tsover": "npm:tsover@latest",
    "tsx": "^4.19.4",
    "typescript": "npm:tsover@latest",
    "unplugin-typegpu": "^0.11.0",
    "vite": "^7.3.2",
    "vite-plugin-solid": "^3.0.0-next.4",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "@solidjs/web": "2.0.0-beta.7",
      "solid-js": "2.0.0-beta.7",
      "babel-preset-solid": "2.0.0-beta.7",
      "typescript": "npm:tsover@latest"
    }
  }
}
