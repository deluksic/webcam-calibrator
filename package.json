{
  "name": "webcam-calibrator",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "ship": "pnpm build && rm -rf /var/www/webcam-calibration.clodhost.com/public/* && cp -r dist/* /var/www/webcam-calibration.clodhost.com/public/"
  },
  "dependencies": {
    "@solidjs/web": "2.0.0-beta.6",
    "solid-js": "2.0.0-beta.6",
    "typegpu": "^0.11.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@webgpu/types": "^0.1.55",
    "babel-preset-solid": "2.0.0-beta.6",
    "jsdom": "^29.0.2",
    "typescript": "^5.7.3",
    "unplugin-typegpu": "^0.11.0",
    "vite": "^7.3.2",
    "vite-plugin-solid": "^3.0.0-next.4",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "@solidjs/web": "2.0.0-beta.6",
      "solid-js": "2.0.0-beta.6",
      "babel-preset-solid": "2.0.0-beta.6"
    }
  }
}
