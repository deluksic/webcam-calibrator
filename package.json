{
  "name": "webcam-calibrator",
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "type": "tsc --noEmit",
    "build": "vite build",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "test": "vitest run",
    "test:subpixel": "vitest run src/tests/subpixel",
    "test:decode": "vitest run src/tests/decode"
  },
  "dependencies": {
    "@deluksic/opencv-calibration-wasm": "^0.2.5",
    "@solidjs/router": "0.17.0-next.2",
    "@solidjs/web": "2.0.0-beta.7",
    "@typegpu/geometry": "github:software-mansion/TypeGPU#08fb40f459b4ac0735711889dd98e19b19e6ab67&path:/packages/typegpu-geometry",
    "comlink": "^4.4.2",
    "solid-js": "2.0.0-beta.7",
    "typegpu": "github:software-mansion/TypeGPU#08fb40f459b4ac0735711889dd98e19b19e6ab67&path:/packages/typegpu",
    "wgpu-matrix": "^3.4.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^25.6.0",
    "@webgpu/types": "^0.1.69",
    "babel-preset-solid": "2.0.0-beta.7",
    "eslint-plugin-typegpu": "^0.11.1",
    "jsdom": "^29.0.2",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "pngjs": "^7.0.0",
    "tsover": "npm:tsover@latest",
    "tsx": "^4.21.0",
    "typescript": "npm:tsover@latest",
    "unplugin-typegpu": "^0.11.3",
    "vite": "^7.3.2",
    "vite-plugin-solid": "^3.0.0-next.4",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowAny": [
        "typegpu"
      ]
    },
    "overrides": {
      "@solidjs/web": "2.0.0-beta.7",
      "solid-js": "2.0.0-beta.7",
      "babel-preset-solid": "2.0.0-beta.7",
      "typescript": "npm:tsover@latest",
      "tinyest": "0.3.1",
      "tinyest-for-wgsl": "0.3.2",
      "typegpu": "github:software-mansion/TypeGPU#08fb40f459b4ac0735711889dd98e19b19e6ab67&path:/packages/typegpu",
      "@typegpu/geometry": "github:software-mansion/TypeGPU#08fb40f459b4ac0735711889dd98e19b19e6ab67&path:/packages/typegpu-geometry"
    }
  }
}
